@code {
    private List<FirebaseChannel>? _channels;
    private FirebaseDBMeta? _metadata;
    private bool _isLoading = true;

    // --- VARIABLES PARA EL MODAL DE SOLICITUD ---
    private bool _mostrarModal = false;
    private bool _enviando = false;
    private bool _solicitudEnviada = false;
    private string _errorValidacion = "";
    private SolicitudCanal _nuevaSolicitud = new();

    // --- VARIABLES PARA EL MODAL DE INFORMACIÓN ---
    private bool _mostrarModalInfo = false;

    private class SolicitudCanal
    {
        public string Nombre { get; set; } = "";
        public string YTLink { get; set; } = "";
        public string Ciudad { get; set; } = "";
        public string Mensaje { get; set; } = "";
    }

    private string _searchText = "";
    private string SearchText
    {
        get => _searchText;
        set { _searchText = value; }
    }

    private static string RemoveDiacritics(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return text;

        var normalizedString = text.Normalize(NormalizationForm.FormD);
        var stringBuilder = new StringBuilder(capacity: normalizedString.Length);

        for (int i = 0; i < normalizedString.Length; i++)
        {
            char c = normalizedString[i];
            var unicodeCategory = CharUnicodeInfo.GetUnicodeCategory(c);
            if (unicodeCategory != UnicodeCategory.NonSpacingMark)
            {
                stringBuilder.Append(c);
            }
        }

        return stringBuilder.ToString().Normalize(NormalizationForm.FormC);
    }

    private IEnumerable<FirebaseChannel> FilteredChannels
    {
        get
        {
            if (_channels == null) return new List<FirebaseChannel>();

            if (string.IsNullOrWhiteSpace(SearchText)) return _channels;

            var cleanSearchText = RemoveDiacritics(SearchText.Trim()).ToLowerInvariant();

            return _channels.Where(c =>
            {
                var cleanName = RemoveDiacritics(c.ChannelName ?? "").ToLowerInvariant();
                var cleanCity = RemoveDiacritics(c.ChannelCity ?? "").ToLowerInvariant();

                return cleanName.Contains(cleanSearchText) || cleanCity.Contains(cleanSearchText);
            });
        }
    }

    private IEnumerable<FirebaseChannel> Streams => FilteredChannels
            .Where(c => c.ChannelType != null && c.ChannelType.Contains("stream", StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(c => c.ChannelLive)
            .ThenByDescending(c => c.LastActivityAt);

    private IEnumerable<FirebaseChannel> PersonalStreams => FilteredChannels
        .Where(c => c.ChannelType != null && c.ChannelType.Contains("personal", StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(c => c.ChannelLive)
        .ThenByDescending(c => c.LastActivityAt);

    private IEnumerable<FirebaseChannel> Televisions => FilteredChannels
        .Where(c => c.ChannelType != null && c.ChannelType.Contains("television", StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(c => c.ChannelLive)
        .ThenByDescending(c => c.LastActivityAt);

    private IEnumerable<FirebaseChannel> Radios => FilteredChannels
        .Where(c => c.ChannelType != null && c.ChannelType.Contains("radio", StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(c => c.ChannelLive)
        .ThenByDescending(c => c.LastActivityAt);

    private HashSet<string> _expandedChannels = new();

    protected override async Task OnInitializedAsync()
    {
        _channels = await ChannelService.GetChannelsAsync();
        _metadata = await ChannelService.GetLastSyncDateTime();

        _isLoading = false;
    }

    private async Task AbrirCanal(FirebaseChannel canal)
    {
        if (!string.IsNullOrEmpty(canal.ChannelLiveUrl))
        {
            await JSRuntime.InvokeVoidAsync("open", canal.ChannelLiveUrl, "_blank");
        }
    }

    private void ToggleInfo(string channelName)
    {
        var safeName = channelName ?? string.Empty;
        if (!_expandedChannels.Contains(safeName))
        {
            _expandedChannels.Clear();
            _expandedChannels.Add(safeName);
        }
        else
        {
            _expandedChannels.Remove(safeName);
        }
    }

    private void CerrarTodasLasTarjetas()
    {
        _expandedChannels.Clear();
    }

    private bool IsExpanded(string channelName) => _expandedChannels.Contains(channelName ?? string.Empty);

    // --- MÉTODOS DEL MODAL DE INFORMACIÓN ---
    private void AbrirModalInfo()
    {
        _mostrarModalInfo = true;
    }

    private void CerrarModalInfo()
    {
        _mostrarModalInfo = false;
    }

    // --- MÉTODOS DEL MODAL DE SOLICITUD ---
    private void AbrirModalSolicitud()
    {
        _nuevaSolicitud = new SolicitudCanal();
        _solicitudEnviada = false;
        _errorValidacion = "";
        _mostrarModal = true;
    }

    private string ObtenerTextoActividad(FirebaseChannel canal)
    {        
        // .ToLocalTime() adapta la hora automáticamente a la de la PC/celular del usuario
        return $"Ultima Actividad: {canal.LastActivityAt.ToLocalTime().ToString("dd/MM/yy - HH:mm")} hs";       
    }

    private void CerrarModalSolicitud()
    {
        _mostrarModal = false;
    }

    private string FormatearSincro(string lastSynced)
    {
        // Asumir que el string está en UTC si no tiene zona
        if (DateTimeOffset.TryParse(lastSynced, null, System.Globalization.DateTimeStyles.AssumeUniversal, out var fecha))
        {
            var ahora = DateTimeOffset.Now;
            var diff = ahora - fecha; // fecha ya es UTC, ahora es local con offset, la resta funciona
            var minutos = diff.TotalMinutes;

            if (minutos < 0) return "---"; // o podrías devolver "---"
            if (minutos < 1) return "ahora mismo";
            if (minutos < 60) return $"hace {Math.Floor(minutos)} min";

            // Mostrar hora local de la última sincro
            return fecha.ToLocalTime().ToString("HH:mm") + " hs";
        }
        return "---";
    }

    private async Task EnviarSolicitud()
    {
        _errorValidacion = "";

        if (string.IsNullOrWhiteSpace(_nuevaSolicitud.Nombre) || string.IsNullOrWhiteSpace(_nuevaSolicitud.YTLink))
        {
            _errorValidacion = "Por favor, completá el nombre y el link del canal.";
            return;
        }

        try
        {
            // --- CONTROL DE SPAM POR LOCAL STORAGE ---
            var spamCountStr = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "zapping_solicitudes");
            int spamCount = string.IsNullOrEmpty(spamCountStr) ? 0 : int.Parse(spamCountStr);

            if (spamCount >= 3)
            {
                _errorValidacion = "¡Epa! Ya enviaste varias solicitudes. Dejanos revisar las que mandaste primero.";
                return;
            }

            _enviando = true;
            StateHasChanged();

            string firebaseUrl = "https://zappingstreaming-default-rtdb.firebaseio.com/Solicitudes.json";


            var response = await Http.PostAsJsonAsync(firebaseUrl, _nuevaSolicitud);

            if (response.IsSuccessStatusCode)
            {
                // Aumentamos el contador en el navegador del usuario si salió todo bien
                await JSRuntime.InvokeVoidAsync("localStorage.setItem", "zapping_solicitudes", (spamCount + 1).ToString());
                _solicitudEnviada = true;
            }
            else
            {
                _errorValidacion = "No se pudo conectar con el servidor. Intentá más tarde.";
            }
        }
        catch (Exception ex)
        {
            _errorValidacion = "Hubo un error al enviar. Intentá de nuevo más tarde.";
        }
        finally
        {
            _enviando = false;
            StateHasChanged();
        }
    }
